# Copier ce fichier en `.env.test.local` à la racine de `apps/admin` (non versionné).
# Valeurs du Supabase **local** (`supabase start`) — aligné sur `apps/mobile/tests/setupEnv.ts`.
#
# Exemple (ports par défaut) :
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=<anon key from `supabase status`>
# SUPABASE_SERVICE_ROLE_KEY=<service_role key from `supabase status`>

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
