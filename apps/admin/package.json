{
  "name": "admin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "migrate:local": "supabase migration up --local --include-all --workdir ../..",
    "migrate:remote": "supabase migration up --linked --include-all --workdir ../..",
    "migrate:all": "npm run migrate:local && npm run migrate:remote",
    "test": "supabase migration up --local --include-all --workdir ../.. && jest",
    "test:integration": "jest --selectProjects integration"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0",
    "@tanstack/react-query": "^5.97.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@winlab/supabase-test-utils": "*",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "typescript": "~5.9.2",
    "vite": "^6.0.3"
  }
}
