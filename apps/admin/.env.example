# Copier ce fichier en `.env` à la racine de `apps/admin` (le fichier `.env` reste local / non versionné).
# Même projet Supabase que le reste de Winlab : Dashboard → Settings → API.
#
# Uniquement des valeurs publiques compatibles navigateur (pas de service_role).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Monitoring (même Edge Function que le mobile ; secret Slack côté Supabase uniquement).
# VITE_MONITORING_SLACK_EDGE_FUNCTION_NAME=monitoring-slack
# VITE_SENTRY_DSN=
