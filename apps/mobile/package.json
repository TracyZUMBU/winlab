{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:prebuild": "expo prebuild --clean -p ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "migrate:local": "supabase migration up --local --include-all --workdir ../..",
    "migrate:remote": "supabase migration up --linked --include-all --workdir ../..",
    "migrate:all": "npm run migrate:local && npm run migrate:remote",
    "seed:staging:v1": "tsx scripts/seed-staging-v1.ts",
    "bump:release": "node ./scripts/bump-release.js",
    "build:apk": "eas build --platform android --profile preview",
    "build:ios-preview": "eas build --platform ios --profile preview",
    "build:ios-production": "eas build --platform ios --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "update:preview": "eas update --channel preview"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.99.1",
    "@tanstack/react-query": "^5.90.21",
    "@winlab/monitoring": "*",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "i18next": "^24.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^15.7.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@winlab/supabase-test-utils": "*",
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eas-cli": "^18.6.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "ts-jest": "^29.3.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
