EXPO_PUBLIC_SUPABASE_URL=url-to-your-supabase-project
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Nom "humain" du service pour le monitoring (visible dans Slack).
EXPO_PUBLIC_SUPABASE_URL=url-to-your-supabase-project
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Nom "humain" du service pour le monitoring (visible dans Slack).
EXPO_PUBLIC_SERVICE_NAME=winlab-mobile

# Nom de la Edge Function Supabase qui relaie les events vers Slack.
EXPO_PUBLIC_MONITORING_SLACK_EDGE_FUNCTION_NAME=monitoring-slack

# Optionnel: DSN Sentry (pour brancher plus tard, le provider est encore un stub).
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Cote Supabase uniquement (Edge Function): mettre SLACK_WEBHOOK_URL dans l'environnement
# de Supabase (pas ici en "EXPO_PUBLIC", car c'est un secret).