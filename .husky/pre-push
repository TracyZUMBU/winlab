#!/usr/bin/env sh
set -e
echo "Running pre-push checks (lint + typecheck, workspaces)..."

npm run lint --if-present -w admin
npm run lint --if-present -w mobile
npm run lint --if-present -w `@winlab/monitoring`
npm run lint --if-present -w `@winlab/supabase-test-utils`

npm run typecheck --if-present -w admin
